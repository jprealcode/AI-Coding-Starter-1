# ============================================================
# Hausverwaltung Rechnungsworkflow — Umgebungsvariablen
# Kopieren nach: .env.local  (wird nicht eingecheckt)
# ============================================================

# Supabase — aus Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://DEIN-PROJEKT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...anon-key...

# Service Role Key — NUR server-seitig, NIEMALS im Client-Code!
# Supabase Dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=eyJ...service-role-key...

# ============================================================
# Wird in späteren Features ergänzt:

# Google OAuth (Gmail + Google Drive — PROJ-3, PROJ-10)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Anthropic Claude API (OCR-Fallback — PROJ-4)
# ANTHROPIC_API_KEY=

# DATEV UNTERNEHMEN online (PROJ-9)
# DATEV_CLIENT_ID=
# DATEV_CLIENT_SECRET=
# ============================================================
